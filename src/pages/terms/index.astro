---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
---

<BaseLayout
  title="Terms of Service - Centrify"
  description="Terms of Service for Centrify products. Choose your product to view the applicable terms."
>
  <Fragment slot="head">
    <style>
      .terms-index {
        padding-top: 120px;
        padding-bottom: 80px;
        min-height: 100vh;
      }

      .terms-container {
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
      }

      .terms-header {
        margin-bottom: 48px;
      }

      .terms-header h1 {
        font-size: 40px;
        font-weight: 700;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
      }

      .terms-header p {
        font-size: 18px;
        color: var(--text-muted);
      }

      .policy-cards {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .policy-card {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 24px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border);
        border-radius: 16px;
        text-decoration: none;
        transition: all 0.2s;
      }

      .policy-card:hover {
        background: rgba(14, 165, 233, 0.1);
        border-color: var(--primary);
        transform: translateY(-2px);
      }

      .policy-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(14, 165, 233, 0.1);
        border-radius: 12px;
        flex-shrink: 0;
      }

      .policy-icon svg {
        width: 24px;
        height: 24px;
        stroke: var(--primary);
      }

      .policy-info {
        text-align: left;
      }

      .policy-info h2 {
        font-size: 18px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 4px;
      }

      .policy-info p {
        font-size: 14px;
        color: var(--text-muted);
        margin: 0;
      }

      .policy-arrow {
        margin-left: auto;
        color: var(--text-muted);
      }

      @media (max-width: 640px) {
        .terms-header h1 {
          font-size: 28px;
        }
      }
    </style>
  </Fragment>

  <Navigation slot="header" />

  <section class="terms-index">
    <div class="container">
      <div class="terms-container">
        <header class="terms-header">
          <h1>Terms of Service</h1>
          <p>Select a product to view its terms of service</p>
        </header>

        <div class="policy-cards">
          <a href="/terms/centricom" class="policy-card">
            <div class="policy-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <div class="policy-info">
              <h2>Centricom</h2>
              <p>AI-powered team productivity platform</p>
            </div>
            <svg class="policy-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
