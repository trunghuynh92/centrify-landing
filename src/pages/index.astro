---
import CentrifyLayout from '../layouts/CentrifyLayout.astro';
import CentrifyNav from '../components/CentrifyNav.astro';
import CentrifyFooter from '../components/CentrifyFooter.astro';

const title = 'Centrify — AI-Powered Operating Ecosystem for SMEs';
const description =
  'Centrify replaces group chats and spreadsheets with an AI-powered ecosystem for bookings, communications, and financial intelligence. Built by operators, for operators.';

const problems = [
  {
    head: 'Your operations live in chat groups',
    body: 'Bookings confirmed via Zalo. Staff updates in a 47-person group chat. Important messages buried under good morning stickers. You can\'t search it, you can\'t report on it, and you definitely can\'t hand it to a new manager.',
  },
  {
    head: 'Your finances live in spreadsheets',
    body: 'Revenue by branch? Let me check the Excel file my accountant sent last Tuesday — wait, which version? Every month you\'re assembling a puzzle from screenshots, bank apps, and gut feeling.',
  },
  {
    head: 'Your decisions live in your head',
    body: 'You know something\'s off at Branch 3 but you can\'t prove it until month-end. By then it\'s too late. You\'re the smartest system in your company — and that\'s the problem.',
  },
];

const steps = [
  {
    n: '01',
    head: 'We learn your business',
    body: 'A 30-minute call to understand your operations, your pain points, and which modules matter most. No generic demo — we map Centrify to how you actually work.',
  },
  {
    n: '02',
    head: 'We set up your ecosystem',
    body: 'We configure your branches, services, team structure, and financial accounts. Migration is handled for you — no IT team required.',
  },
  {
    n: '03',
    head: 'Your team starts using it',
    body: 'Training takes hours, not weeks. Your staff already knows Zalo — CentriCOM meets them there. CARA replaces the notebook. CentriFIN replaces the spreadsheet.',
  },
  {
    n: '04',
    head: 'You see the full picture',
    body: 'Within the first month, you\'ll have real-time visibility across operations, communications, and finances — everything in one place, for the first time.',
  },
];

const stats = [
  { v: '10', l: 'Branches powered by CARA' },
  { v: '15,000+', l: 'Families served' },
  { v: '100%', l: 'Built in-house' },
];
---

<CentrifyLayout title={title} description={description}>
  <CentrifyNav slot="header" variant="over-dark" />

  <!-- ===== 1. HERO ===== -->
  <section class="hero section section--dark" id="top">
    <div class="dotgrid"></div>
    <div class="container hero__inner">
      <span class="eyebrow reveal">Built for Vietnamese SMEs</span>
      <h1 class="reveal">
        Stop running your business through
        <span class="hero__accent">group chats</span> and
        <span class="hero__accent hero__accent--amber">spreadsheets.</span>
      </h1>
      <p class="hero__sub reveal">
        Centrify is an AI-powered operating ecosystem built for SMEs — by a founder who runs one.
        Bookings, communications, and financial intelligence in one place.
      </p>
      <div class="hero__ctas reveal">
        <a href="#pricing" class="btn btn-primary">Get Early Access →</a>
        <a href="#how" class="btn btn-ghost">See How It Works</a>
      </div>

      <div class="hero__orbit reveal">
        <svg viewBox="0 0 600 200" role="img" aria-label="Three interconnected modules">
          <defs>
            <linearGradient id="orbit" x1="0" x2="1">
              <stop offset="0" stop-color="#00d4aa" stop-opacity="0.0" />
              <stop offset="0.5" stop-color="#00d4aa" stop-opacity="0.55" />
              <stop offset="1" stop-color="#f59e0b" stop-opacity="0.0" />
            </linearGradient>
          </defs>
          <line x1="110" y1="100" x2="490" y2="100" stroke="url(#orbit)" stroke-width="1" />
          <g>
            <circle cx="110" cy="100" r="44" fill="none" stroke="rgba(255,255,255,0.18)" />
            <circle cx="110" cy="100" r="6" fill="#00d4aa" />
            <text x="110" y="160" text-anchor="middle" class="hero__orbitLabel">CARA</text>
          </g>
          <g>
            <circle cx="300" cy="100" r="44" fill="none" stroke="rgba(255,255,255,0.18)" />
            <circle cx="300" cy="100" r="6" fill="#60a5fa" />
            <text x="300" y="160" text-anchor="middle" class="hero__orbitLabel">CentriCOM</text>
          </g>
          <g>
            <circle cx="490" cy="100" r="44" fill="none" stroke="rgba(255,255,255,0.18)" />
            <circle cx="490" cy="100" r="6" fill="#f59e0b" />
            <text x="490" y="160" text-anchor="middle" class="hero__orbitLabel">CentriFIN</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- ===== 2. PROBLEM ===== -->
  <section class="section section--soft" id="problem">
    <div class="container">
      <div class="sectionHead reveal">
        <span class="eyebrow">Sound familiar?</span>
        <h2>Running an SME today feels like juggling knives.</h2>
      </div>
      <div class="problem__grid">
        {problems.map((p, i) => (
          <article class={`problem__card reveal reveal--${i}`}>
            <span class="problem__num mono">0{i + 1}</span>
            <h3>{p.head}</h3>
            <p class="muted">{p.body}</p>
          </article>
        ))}
      </div>
      <p class="problem__close reveal">
        You don't need another app. <span class="problem__closeAccent">You need an operating system.</span>
      </p>
    </div>
  </section>

  <!-- ===== 3. ECOSYSTEM ===== -->
  <section class="section" id="ecosystem">
    <div class="container">
      <div class="sectionHead reveal">
        <span class="eyebrow">The ecosystem</span>
        <h2>Three tools. One ecosystem. Zero chaos.</h2>
        <p class="sectionHead__sub muted">
          Each module works standalone. Together, they give you something no SME tool in Vietnam offers:
          a complete picture of your business.
        </p>
      </div>

      <!-- CARA -->
      <article id="cara" class="module reveal" style="--accent: var(--c-cara)">
        <div class="module__viz">
          <svg viewBox="0 0 160 160" aria-hidden="true">
            <rect x="10" y="24" width="140" height="126" rx="10" fill="none" stroke="currentColor" stroke-opacity="0.25" />
            <line x1="10" y1="54" x2="150" y2="54" stroke="currentColor" stroke-opacity="0.25" />
            {Array.from({ length: 5 }).map((_, i) => (
              <line x1={10 + (i + 1) * 28} y1="54" x2={10 + (i + 1) * 28} y2="150" stroke="currentColor" stroke-opacity="0.15" />
            ))}
            {Array.from({ length: 3 }).map((_, r) => (
              <line x1="10" y1={54 + (r + 1) * 30} x2="150" y2={54 + (r + 1) * 30} stroke="currentColor" stroke-opacity="0.15" />
            ))}
            <rect x="40" y="62" width="52" height="20" rx="4" fill="currentColor" fill-opacity="0.9" />
            <rect x="96" y="92" width="40" height="20" rx="4" fill="currentColor" fill-opacity="0.55" />
            <rect x="12" y="122" width="60" height="20" rx="4" fill="currentColor" fill-opacity="0.35" />
            <circle cx="140" cy="38" r="4" fill="currentColor" />
          </svg>
        </div>
        <div class="module__body">
          <div class="module__tag mono">Operations &amp; Booking Intelligence</div>
          <h3>CARA</h3>
          <p class="module__desc">
            Branch-level booking, point-of-sale, and daily operations management.
            Your front desk, your schedule, your service delivery — running on one system instead of three apps and a notebook.
          </p>
          <ul class="module__feats mono">
            <li>Multi-branch booking</li>
            <li>POS &amp; payments</li>
            <li>Staff scheduling</li>
            <li>Service catalog</li>
            <li>Walk-in &amp; online booking</li>
            <li>Real-time availability</li>
          </ul>
          <p class="module__for muted">
            For: service businesses, spas, clinics, studios, academies.
          </p>
        </div>
      </article>

      <!-- CentriCOM -->
      <article id="centricom" class="module module--reverse reveal" style="--accent: var(--c-centricom)">
        <div class="module__viz">
          <svg viewBox="0 0 160 160" aria-hidden="true">
            <circle cx="80" cy="80" r="58" fill="none" stroke="currentColor" stroke-opacity="0.18" />
            <circle cx="80" cy="80" r="34" fill="none" stroke="currentColor" stroke-opacity="0.25" />
            <line x1="80" y1="80" x2="28" y2="48" stroke="currentColor" stroke-opacity="0.3" />
            <line x1="80" y1="80" x2="132" y2="48" stroke="currentColor" stroke-opacity="0.3" />
            <line x1="80" y1="80" x2="40" y2="124" stroke="currentColor" stroke-opacity="0.3" />
            <line x1="80" y1="80" x2="124" y2="124" stroke="currentColor" stroke-opacity="0.3" />
            <circle cx="80" cy="80" r="14" fill="currentColor" />
            <circle cx="28" cy="48" r="7" fill="currentColor" fill-opacity="0.5" />
            <circle cx="132" cy="48" r="7" fill="currentColor" fill-opacity="0.5" />
            <circle cx="40" cy="124" r="7" fill="currentColor" fill-opacity="0.5" />
            <circle cx="124" cy="124" r="7" fill="currentColor" fill-opacity="0.5" />
          </svg>
        </div>
        <div class="module__body">
          <div class="module__tag mono">Communications &amp; Organizational Intelligence</div>
          <h3>CentriCOM</h3>
          <p class="module__desc">
            No new app for your team to learn.
            <strong>Centry</strong> — your AI agent — lives inside Zalo and speaks natural language.
            Announcements, tasks, check-ins, and alerts land where your staff already are.
          </p>
          <ul class="module__feats mono">
            <li>Zalo OA integration</li>
            <li>AI agent in chat</li>
            <li>Team announcements</li>
            <li>Task assignments</li>
            <li>Read receipts &amp; follow-ups</li>
            <li>Automated daily briefings</li>
          </ul>
          <p class="module__for muted">
            For: multi-location businesses, franchise operators, distributed teams.
          </p>
        </div>
      </article>

      <!-- CentriFIN -->
      <article id="centrifin" class="module reveal" style="--accent: var(--c-centrifin)">
        <div class="module__viz">
          <svg viewBox="0 0 160 160" aria-hidden="true">
            <line x1="16" y1="140" x2="150" y2="140" stroke="currentColor" stroke-opacity="0.25" />
            <line x1="16" y1="16" x2="16" y2="140" stroke="currentColor" stroke-opacity="0.25" />
            {[
              [30, 100],
              [54, 70],
              [78, 85],
              [102, 45],
              [126, 60],
            ].map(([x, h], i) => (
              <rect x={x} y={140 - h} width="14" height={h} rx="2" fill="currentColor" fill-opacity={0.3 + i * 0.13} />
            ))}
            <polyline
              points="37,40 61,30 85,48 109,24 133,34"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              opacity="0.85"
            />
            {[[37,40],[61,30],[85,48],[109,24],[133,34]].map(([x,y]) => (
              <circle cx={x} cy={y} r="3" fill="currentColor" />
            ))}
          </svg>
        </div>
        <div class="module__body">
          <div class="module__tag mono">Financial Intelligence</div>
          <h3>CentriFIN</h3>
          <p class="module__desc">
            See your money clearly — across branches, accounts, and time periods.
            No more waiting for your accountant's monthly Excel.
            CentriFIN connects your financial data and gives you the picture you need to make decisions today, not next month.
          </p>
          <ul class="module__feats mono">
            <li>Multi-branch financial overview</li>
            <li>Revenue tracking</li>
            <li>Expense categorization</li>
            <li>Bank transaction capture</li>
            <li>Cashflow visibility</li>
            <li>Custom reports</li>
          </ul>
          <p class="module__for muted">
            For: any SME owner who's tired of flying blind.
          </p>
        </div>
      </article>
    </div>
  </section>

  <!-- ===== 4. HOW IT WORKS ===== -->
  <section class="section section--soft" id="how">
    <div class="container">
      <div class="sectionHead reveal">
        <span class="eyebrow">How it works</span>
        <h2>From chaos to clarity in weeks, not months.</h2>
      </div>
      <ol class="steps">
        {steps.map((s) => (
          <li class="step reveal">
            <span class="step__n mono">{s.n}</span>
            <h3>{s.head}</h3>
            <p class="muted">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== 5. ORIGIN STORY ===== -->
  <section class="section section--dark" id="story">
    <div class="dotgrid"></div>
    <div class="container story">
      <div class="sectionHead reveal">
        <span class="eyebrow">Our story</span>
        <h2>Built from the inside out.</h2>
      </div>
      <div class="story__body reveal">
        <p>Centrify wasn't born in a startup accelerator. It was born in a baby spa.</p>
        <p>
          Our founder runs Pamper Me Baby — 10 branches, 15,000+ families across Ho Chi Minh City.
          He also runs Younique Academy, a music and performing arts school.
          When he went looking for software to manage booking, staff communication, and finances across all these locations, nothing fit.
        </p>
        <p>
          The international tools didn't understand Vietnamese workflows.
          The local tools were just digitized paperwork.
          And the "enterprise" solutions cost more than most SMEs make in a quarter.
        </p>
        <p>So he built his own. First for internal use. Then for everyone.</p>
        <p class="story__punch">
          Centrify is what happens when the person building the software is also the person using it to run a real business, every single day.
          <br /><span class="story__punchAccent">That's why it works.</span>
        </p>
        <a href="https://prudentpartnersgroup.com" class="story__link" target="_blank" rel="noopener">
          Meet our parent company →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 6. SOCIAL PROOF ===== -->
  <section class="section" id="proof">
    <div class="container proof">
      <div class="sectionHead reveal">
        <span class="eyebrow">The operator difference</span>
        <h2>Powering our own portfolio first.</h2>
        <p class="sectionHead__sub muted">
          Centrify runs the daily operations of Pamper Me Baby (10 branches) and Younique Academy.
          We're proving the ecosystem on our own businesses before we ask you to trust it with yours.
        </p>
      </div>
      <div class="proof__stats">
        {stats.map((s) => (
          <div class="stat reveal">
            <div class="stat__v">{s.v}</div>
            <div class="stat__l mono">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 7. PRICING / WAITLIST ===== -->
  <section class="section section--soft" id="pricing">
    <div class="container pricing">
      <div class="sectionHead reveal">
        <span class="eyebrow">Early access</span>
        <h2>Simple pricing. No enterprise sales calls.</h2>
        <p class="sectionHead__sub muted">
          We're onboarding early partners now. Tell us about your business and we'll set up a personalized walkthrough.
        </p>
      </div>

      <form class="waitlist reveal" id="waitlist" method="POST" action="/api/waitlist" novalidate>
        <div class="waitlist__hp" aria-hidden="true">
          <label>Company (leave blank)<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
        </div>
        <div class="waitlist__row">
          <label class="field">
            <span class="field__label mono">Your name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label class="field">
            <span class="field__label mono">Business name</span>
            <input type="text" name="business" required autocomplete="organization" />
          </label>
        </div>
        <div class="waitlist__row">
          <label class="field">
            <span class="field__label mono">Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label class="field">
            <span class="field__label mono">Branches / locations</span>
            <input type="text" name="branches" placeholder="e.g. 3" />
          </label>
        </div>
        <label class="field">
          <span class="field__label mono">What's your biggest operational headache?</span>
          <textarea name="headache" rows="4" placeholder="A sentence or two is fine."></textarea>
        </label>
        <div class="waitlist__actions">
          <button type="submit" class="btn btn-primary" data-waitlist-submit>
            <span data-label>Apply for Early Access →</span>
          </button>
          <p class="waitlist__note muted">We reply to every application. Usually within a day.</p>
        </div>
        <p class="waitlist__status" data-waitlist-status role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <!-- ===== 8. CONTACT ===== -->
  <section class="section section--dark" id="contact">
    <div class="dotgrid"></div>
    <div class="container cta">
      <div class="reveal">
        <h2>Ready to see your business clearly?</h2>
        <p class="cta__sub">
          Book a 30-minute call. We'll show you exactly how Centrify fits your operations —
          no generic demo, no pressure.
        </p>
        <div class="cta__actions">
          <a href="#pricing" class="btn btn-primary">Book a Call</a>
          <a href="mailto:hello@centrify.io" class="btn btn-ghost">hello@centrify.io</a>
        </div>
        <p class="cta__ps muted">Or just say hi — we reply to every message.</p>
      </div>
    </div>
  </section>

  <CentrifyFooter slot="footer" />

  <Fragment slot="head">
    <style is:global>
      /* ========== HERO ========== */
      .hero { padding-top: 160px; padding-bottom: 120px; overflow: hidden; }
      .hero__inner { position: relative; text-align: center; }
      .hero .eyebrow { margin-bottom: 28px; justify-content: center; }
      .hero h1 {
        max-width: 18ch;
        margin: 0 auto 28px;
      }
      .hero__accent {
        color: var(--c-teal);
        font-style: italic;
        font-weight: 500;
      }
      .hero__accent--amber { color: var(--c-amber); }
      .hero__sub {
        color: var(--c-mute-dark);
        font-size: clamp(16px, 1.4vw, 19px);
        max-width: 62ch;
        margin: 0 auto 40px;
        line-height: 1.65;
      }
      .hero__ctas {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 80px;
      }
      .hero__orbit {
        max-width: 560px;
        margin: 0 auto;
      }
      .hero__orbitLabel {
        font-family: var(--f-mono);
        font-size: 11px;
        fill: rgba(255,255,255,0.6);
        letter-spacing: 0.2em;
      }

      /* ========== SECTION HEAD ========== */
      .sectionHead {
        max-width: 720px;
        margin: 0 auto 72px;
        text-align: center;
      }
      .sectionHead .eyebrow { justify-content: center; margin-bottom: 20px; }
      .sectionHead h2 { margin-bottom: 16px; }
      .sectionHead__sub {
        font-size: 17px;
        line-height: 1.65;
      }

      /* ========== PROBLEM ========== */
      .problem__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        margin-bottom: 56px;
      }
      .problem__card {
        background: var(--c-paper);
        border: 1px solid var(--c-line);
        border-radius: var(--radius-lg);
        padding: 36px 32px;
      }
      .problem__num {
        display: block;
        color: var(--c-teal);
        font-size: 13px;
        margin-bottom: 20px;
        letter-spacing: 0.18em;
      }
      .problem__card h3 { margin-bottom: 14px; }
      .problem__close {
        text-align: center;
        font-family: var(--f-display);
        font-size: clamp(22px, 2.2vw, 30px);
        font-weight: 500;
        letter-spacing: -0.01em;
      }
      .problem__closeAccent { color: var(--c-teal); font-style: italic; }
      @media (max-width: 900px) {
        .problem__grid { grid-template-columns: 1fr; gap: 20px; }
      }

      /* ========== ECOSYSTEM MODULES ========== */
      .module {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 64px;
        align-items: center;
        padding: 56px 0;
        border-top: 1px solid var(--c-line);
      }
      .module:last-of-type { border-bottom: 1px solid var(--c-line); }
      .module--reverse { grid-template-columns: 1fr 340px; }
      .module--reverse .module__body { order: 1; }
      .module--reverse .module__viz { order: 2; }
      .module__viz {
        background: var(--c-paper-2);
        border-radius: var(--radius-lg);
        aspect-ratio: 1 / 1;
        display: grid;
        place-items: center;
        color: var(--accent);
        padding: 36px;
      }
      .module__viz svg { width: 100%; height: 100%; }
      .module__tag {
        display: inline-block;
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 14px;
      }
      .module__body h3 {
        font-size: clamp(40px, 4vw, 56px);
        font-weight: 800;
        letter-spacing: -0.025em;
        margin-bottom: 18px;
      }
      .module__desc {
        font-size: 17px;
        line-height: 1.65;
        color: var(--c-ink-soft);
        margin-bottom: 24px;
        max-width: 58ch;
      }
      .module__desc strong { color: var(--c-ink); font-weight: 600; }
      .module__feats {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px 24px;
        font-size: 13px;
        color: var(--c-mute);
        margin-bottom: 22px;
      }
      .module__feats li {
        position: relative;
        padding-left: 18px;
      }
      .module__feats li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 8px;
        width: 8px;
        height: 1px;
        background: var(--accent);
      }
      .module__for { font-size: 14px; }

      @media (max-width: 900px) {
        .module,
        .module--reverse {
          grid-template-columns: 1fr;
          gap: 32px;
          padding: 44px 0;
        }
        .module--reverse .module__body { order: 2; }
        .module--reverse .module__viz { order: 1; }
        .module__viz { max-width: 300px; justify-self: start; }
      }

      /* ========== HOW IT WORKS ========== */
      .steps {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 28px;
        counter-reset: step;
      }
      .step {
        background: var(--c-paper);
        border: 1px solid var(--c-line);
        border-radius: var(--radius-lg);
        padding: 32px 28px;
        position: relative;
      }
      .step__n {
        display: block;
        font-size: 28px;
        font-weight: 500;
        color: var(--c-teal);
        letter-spacing: 0.08em;
        margin-bottom: 20px;
      }
      .step h3 { margin-bottom: 12px; font-size: 20px; }
      .step p { font-size: 15px; }
      @media (max-width: 1000px) { .steps { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 560px) { .steps { grid-template-columns: 1fr; } }

      /* ========== STORY ========== */
      .story__body {
        max-width: 70ch;
        margin: 0 auto;
        font-size: 18px;
        line-height: 1.8;
      }
      .story__body p { color: var(--c-mute-dark); margin-bottom: 22px; }
      .story__punch {
        color: var(--c-paper);
        font-family: var(--f-display);
        font-size: clamp(22px, 2.4vw, 30px);
        font-weight: 500;
        line-height: 1.35;
        letter-spacing: -0.01em;
        margin-top: 32px;
      }
      .story__punchAccent { color: var(--c-teal); font-style: italic; }
      .story__link {
        display: inline-block;
        margin-top: 28px;
        color: var(--c-paper);
        border-bottom: 1px solid var(--c-teal);
        padding-bottom: 4px;
        font-size: 14px;
        letter-spacing: 0.02em;
      }
      .story__link:hover { color: var(--c-teal); }

      /* ========== PROOF ========== */
      .proof__stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        border: 1px solid var(--c-line);
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: var(--c-paper-2);
      }
      .stat {
        padding: 40px 24px;
        background: var(--c-paper);
        text-align: center;
      }
      .stat__v {
        font-family: var(--f-display);
        font-weight: 800;
        font-size: clamp(36px, 4vw, 52px);
        color: var(--c-ink);
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .stat__l {
        color: var(--c-mute);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      @media (max-width: 820px) { .proof__stats { grid-template-columns: repeat(2, 1fr); } }

      /* ========== PRICING / WAITLIST ========== */
      .waitlist {
        max-width: 720px;
        margin: 0 auto;
        background: var(--c-paper);
        border: 1px solid var(--c-line);
        border-radius: var(--radius-lg);
        padding: 40px;
        display: grid;
        gap: 20px;
      }
      .waitlist__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
      .field { display: grid; gap: 8px; }
      .field__label {
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--c-mute);
      }
      .field input,
      .field textarea {
        font: inherit;
        font-family: var(--f-body);
        background: var(--c-paper-2);
        border: 1px solid var(--c-line);
        border-radius: var(--radius-md);
        padding: 14px 16px;
        color: var(--c-ink);
        transition: border-color 0.15s ease, background 0.15s ease;
        width: 100%;
        resize: vertical;
      }
      .field input:focus,
      .field textarea:focus {
        outline: none;
        border-color: var(--c-teal);
        background: var(--c-paper);
      }
      .waitlist__actions {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 6px;
      }
      .waitlist__note { font-size: 13px; }
      .waitlist__hp {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }
      .waitlist__status { font-size: 14px; min-height: 20px; margin: 0; }
      .waitlist__status.is-err { color: #b91c1c; }
      .waitlist__status.is-ok { color: #047857; }
      @media (max-width: 640px) {
        .waitlist { padding: 28px; }
        .waitlist__row { grid-template-columns: 1fr; }
      }

      /* ========== CTA ========== */
      .cta { text-align: center; position: relative; }
      .cta h2 { max-width: 22ch; margin: 0 auto 18px; }
      .cta__sub {
        color: var(--c-mute-dark);
        font-size: 18px;
        max-width: 56ch;
        margin: 0 auto 32px;
        line-height: 1.65;
      }
      .cta__actions {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 20px;
      }
      .cta__ps { font-size: 14px; }
    </style>
  </Fragment>

  <Fragment slot="scripts">
    <script is:inline>
      (function () {
        const form = document.getElementById('waitlist');
        if (!form) return;
        const status = form.querySelector('[data-waitlist-status]');
        const btn = form.querySelector('[data-waitlist-submit]');
        const label = btn && btn.querySelector('[data-label]');
        const originalLabel = label ? label.textContent : '';

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          status.className = 'waitlist__status';
          status.textContent = '';
          if (label) label.textContent = 'Sending…';
          btn && (btn.disabled = true);

          const data = Object.fromEntries(new FormData(form).entries());
          try {
            const res = await fetch('/api/waitlist', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });
            if (!res.ok) {
              const msg = await res.text().catch(() => '');
              throw new Error(msg || 'Something went wrong. Try again or email hello@centrify.io.');
            }
            status.className = 'waitlist__status is-ok';
            status.textContent = "Thanks — we'll be in touch shortly.";
            form.reset();
          } catch (err) {
            status.className = 'waitlist__status is-err';
            status.textContent = err.message || 'Something went wrong. Try again or email hello@centrify.io.';
          } finally {
            if (label) label.textContent = originalLabel;
            btn && (btn.disabled = false);
          }
        });
      })();
    </script>
  </Fragment>
</CentrifyLayout>
